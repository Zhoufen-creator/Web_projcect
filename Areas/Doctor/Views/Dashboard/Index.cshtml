@using DoAnWeb.Models
@{
    ViewData["Title"] = "Dashboard Bác Sĩ";

    var doctor = ViewBag.Doctor as Doctor;
    var todayAppointments = ViewBag.TodayAppointments as List<Appointment>;
    var totalPatients = (int)ViewBag.TotalPatients;
    var totalExaminations = (int)ViewBag.TotalExaminations;
}

<div class="container mt-4">
    <h2 class="mb-4">Trang Bác Sĩ</h2>

    @if (doctor != null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                Thông tin bác sĩ
            </div>
            <div class="card-body">
                <p><strong>Họ tên:</strong> @doctor.User.Name</p>
                <p><strong>Chuyên khoa:</strong> @doctor.Specialty</p>
                <p><strong>Số chứng chỉ:</strong> @doctor.LicenseNumber</p>
                <p><strong>Bằng cấp:</strong> @doctor.Qualifications</p>

                <a asp-area="Doctor" asp-controller="Profile" asp-action="Index" class="btn btn-outline-primary">
                    Xem / sửa hồ sơ
                </a>
            </div>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h5>Tổng bệnh nhân</h5>
                    <h2>@totalPatients</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h5>Tổng phiếu khám</h5>
                    <h2>@totalExaminations</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h5>Chức năng nhanh</h5>
                    <a asp-area="Doctor" asp-controller="Appointment" asp-action="Today" class="btn btn-success btn-sm mb-2">Lịch hôm nay</a>
                    <br />
                    <a asp-area="Doctor" asp-controller="MedicalExamination" asp-action="Index" class="btn btn-info btn-sm text-white">Phiếu khám</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            Lịch khám hôm nay
        </div>
        <div class="card-body">
            @if (todayAppointments != null && todayAppointments.Any())
            {
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Thời gian</th>
                            <th>Bệnh nhân</th>
                            <th>Lý do khám</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in todayAppointments)
                        {
                            <tr>
                                <td>@item.ScheduledDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.Patient.User.Name</td>
                                <td>@item.ReasonForVisit</td>
                                <td>@item.Status</td>
                                <td>
                                    <a asp-area="Doctor" asp-controller="MedicalExamination" asp-action="CreateOrEdit" asp-route-appointmentId="@item.Id" class="btn btn-sm btn-primary">
                                        Khám bệnh
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">Hôm nay chưa có lịch khám.</p>
            }
        </div>
    </div>
</div>