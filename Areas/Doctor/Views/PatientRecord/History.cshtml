@model List<DoAnWeb.Models.MedicalExamination>
@using DoAnWeb.Models

@{
    ViewData["Title"] = "Lịch sử khám bệnh";
    var patient = ViewBag.Patient as Patient;
}

<section class="doctor-hero">
    <div class="doctor-card doctor-hero-main">
        <div class="doctor-page-badge">
            <i class="bi bi-clock-history"></i>
            <span>Hồ sơ điều trị bệnh nhân</span>
        </div>

        <h2>Theo dõi toàn bộ lịch sử khám bệnh để hỗ trợ đánh giá liên tục và ra quyết định chính xác hơn</h2>

        <p>
            Màn hình này tập trung các lần khám đã thực hiện, bao gồm triệu chứng, chẩn đoán,
            lời dặn và đơn thuốc để bác sĩ dễ dàng tra cứu lại trong quá trình chăm sóc bệnh nhân.
        </p>

        <div class="doctor-hero-actions">
            <a asp-area="Doctor" asp-controller="MedicalExamination" asp-action="Index" class="doctor-btn doctor-btn-primary">
                <i class="bi bi-file-earmark-medical"></i>
                <span>Danh sách phiếu khám</span>
            </a>

            <a asp-area="Doctor" asp-controller="Appointment" asp-action="Today" class="doctor-btn doctor-btn-outline">
                <i class="bi bi-calendar-check"></i>
                <span>Lịch khám hôm nay</span>
            </a>
        </div>
    </div>

    <aside class="doctor-highlight-card">
        <h3>Thông tin bệnh nhân</h3>
        <p>
            Kiểm tra nhanh người bệnh trước khi xem lại lịch sử điều trị.
        </p>

        @if (patient != null)
        {
            <div class="doctor-highlight-list">
                <div class="doctor-highlight-item">
                    <i class="bi bi-person-badge"></i>
                    <div>
                        <strong>Họ tên bệnh nhân</strong>
                        <span>@patient.User.Name</span>
                    </div>
                </div>

                <div class="doctor-highlight-item">
                    <i class="bi bi-hash"></i>
                    <div>
                        <strong>Mã bệnh nhân</strong>
                        <span>@patient.Id</span>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="doctor-empty pt-3 pb-0">
                <p>Không tìm thấy thông tin bệnh nhân.</p>
            </div>
        }
    </aside>
</section>

<section class="doctor-records-wrap">
    @if (Model != null && Model.Any())
    {
        @foreach (var exam in Model)
        {
            <article class="doctor-record-card">
                <div class="doctor-record-head">
                    <div>
                        <div class="doctor-record-date">
                            <i class="bi bi-calendar2-heart me-2"></i>
                            Ngày khám: @exam.StartTime?.ToString("dd/MM/yyyy HH:mm")
                        </div>
                        <h3>Thông tin buổi khám</h3>
                    </div>

                    <span class="doctor-status-badge">@exam.Status</span>
                </div>

                <div class="doctor-record-body">
                    <div class="doctor-record-grid">
                        <div class="doctor-record-block">
                            <h4>Triệu chứng</h4>
                            <p>@(!string.IsNullOrWhiteSpace(exam.Symptoms) ? exam.Symptoms : "Chưa cập nhật")</p>
                        </div>

                        <div class="doctor-record-block">
                            <h4>Chẩn đoán</h4>
                            <p>@(!string.IsNullOrWhiteSpace(exam.Diagnosis) ? exam.Diagnosis : "Chưa cập nhật")</p>
                        </div>

                        <div class="doctor-record-block doctor-record-block-full">
                            <h4>Lời dặn của bác sĩ</h4>
                            <p>@(!string.IsNullOrWhiteSpace(exam.DoctorAvoid) ? exam.DoctorAvoid : "Chưa cập nhật")</p>
                        </div>

                        <div class="doctor-record-block doctor-record-block-full">
                            <h4>Đơn thuốc</h4>

                            @if (exam.Prescriptions != null && exam.Prescriptions.Any())
                            {
                                <div class="doctor-prescription-list">
                                    @foreach (var p in exam.Prescriptions)
                                    {
                                        <div class="doctor-prescription-item">
                                            <div class="doctor-prescription-name">
                                                <i class="bi bi-capsule-pill"></i>
                                                <strong>@p.Medicine?.Name</strong>
                                            </div>
                                            <span>Số lượng: @p.Quantity</span>
                                            <span>Liều dùng: @p.Dosage</span>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="doctor-record-empty-text">Không có thuốc được kê trong lần khám này.</p>
                            }
                        </div>
                    </div>
                </div>
            </article>
        }
    }
    else
    {
        <div class="doctor-empty doctor-form-card">
            <div class="doctor-empty-icon">
                <i class="bi bi-journal-x"></i>
            </div>
            <h4>Chưa có lịch sử khám</h4>
            <p>Hiện chưa có dữ liệu khám bệnh để hiển thị cho bệnh nhân này.</p>
        </div>
    }
</section>