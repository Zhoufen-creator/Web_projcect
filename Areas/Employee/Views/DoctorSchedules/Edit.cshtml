@model DoAnWeb.Areas.Employee.ViewModels.DoctorScheduleVM

@{
    ViewData["Title"] = "Sửa ca làm";
}

<div class="employee-page-top">
    <div>
        <div class="employee-topbar-badge">
            <i class="bi bi-pencil-square"></i>
            Chỉnh sửa ca làm
        </div>
        <h1 class="employee-topbar-title">Cập nhật ca làm bác sĩ</h1>
    </div>
</div>

<div class="employee-form-card">
    <div class="employee-form-head">
        <h3>Thông tin ca làm</h3>
        <p>Điều chỉnh chuyên khoa, bác sĩ, thời gian làm việc và giới hạn số bệnh nhân.</p>
    </div>

    <form asp-area="Employee" asp-controller="DoctorSchedules" asp-action="Edit" method="post" class="employee-form-body">
        <input asp-for="Id" type="hidden" />

        <div asp-validation-summary="All" class="alert alert-danger employee-validation"></div>

        <!-- Section: Chuyên khoa & Bác sĩ -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
            <!-- Chuyên khoa (bên trái) -->
            <div class="employee-form-group">
                <label class="employee-label">Chuyên khoa</label>
                <select asp-for="SpecialtyId" id="specialtySelect" asp-items="ViewBag.SpecialtyId" class="employee-select">
                    <option value="">-- Chọn chuyên khoa --</option>
                </select>
                <span asp-validation-for="SpecialtyId" class="text-danger"></span>
            </div>

            <!-- Bác sĩ (bên phải) -->
            <div class="employee-form-group">
                <label class="employee-label">Bác sĩ</label>
                <div style="position: relative;">
                    <input type="text" id="doctorSearch" class="employee-input" placeholder="Nhập tên bác sĩ..." autocomplete="off" />
                    <div id="doctorSuggestions" style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #ddd; border-top: none; max-height: 200px; overflow-y: auto; display: none; z-index: 10;"></div>
                </div>
                <input type="hidden" asp-for="DoctorId" id="doctorIdHidden" />
                <span asp-validation-for="DoctorId" class="text-danger"></span>
                <small id="selectedDoctorInfo" style="color: #666; display: none; margin-top: 5px;"></small>
            </div>
        </div>

        <div class="employee-form-grid">
            <div class="employee-form-group">
                <label class="employee-label">Số bệnh nhân tối đa</label>
                <input asp-for="MaxPatient" class="employee-input" />
                <span asp-validation-for="MaxPatient" class="text-danger"></span>
            </div>

            <div class="employee-form-group">
                <label class="employee-label">Thời gian bắt đầu</label>
                <input asp-for="StartTime" type="datetime-local" class="employee-input" />
                <span asp-validation-for="StartTime" class="text-danger"></span>
            </div>

            <div class="employee-form-group">
                <label class="employee-label">Thời gian kết thúc</label>
                <input asp-for="EndTime" type="datetime-local" class="employee-input" />
                <span asp-validation-for="EndTime" class="text-danger"></span>
            </div>

            <div class="employee-form-actions">
                <button type="submit" class="employee-primary-btn">
                    <i class="bi bi-check2-circle"></i>
                    Cập nhật
                </button>

                <a asp-area="Employee" asp-controller="DoctorSchedules" asp-action="Index" class="employee-secondary-btn">
                    Quay lại
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let selectedDoctorId = null;
        let allDoctors = [];

        // Khởi tạo
        async function initEditPage() {
            const specialtyId = document.getElementById('specialtySelect').value;
            if (specialtyId) {
                await loadDoctorsForSpecialty(specialtyId);
                // Hiển thị tên bác sĩ hiện tại
                const doctorIdHidden = document.getElementById('doctorIdHidden').value;
                if (doctorIdHidden) {
                    const doctor = allDoctors.find(d => d.id == doctorIdHidden);
                    if (doctor) {
                        document.getElementById('doctorSearch').value = doctor.name;
                        document.getElementById('selectedDoctorInfo').textContent = '✓ Đã chọn: ' + doctor.name;
                        document.getElementById('selectedDoctorInfo').style.display = 'block';
                    }
                }
            }
        }

        async function loadDoctorsForSpecialty(specialtyId) {
            try {
                const response = await fetch(`/Employee/DoctorSchedules/SearchDoctors?specialtyId=${specialtyId}`);
                if (response.ok) {
                    allDoctors = await response.json();
                }
            } catch (error) {
                console.error('Error fetching doctors:', error);
            }
        }

        // Event: Khi thay đổi chuyên khoa
        document.getElementById('specialtySelect').addEventListener('change', async function () {
            const specialtyId = this.value;
            document.getElementById('doctorSearch').value = '';
            document.getElementById('doctorIdHidden').value = '';
            document.getElementById('selectedDoctorInfo').style.display = 'none';
            document.getElementById('doctorSuggestions').style.display = 'none';
            selectedDoctorId = null;
            allDoctors = [];

            if (!specialtyId) {
                return;
            }

            await loadDoctorsForSpecialty(specialtyId);
        });

        // Event: Khi nhập tên bác sĩ
        document.getElementById('doctorSearch').addEventListener('input', function () {
            const searchText = this.value.toLowerCase().trim();
            const suggestionsDiv = document.getElementById('doctorSuggestions');

            if (!searchText || allDoctors.length === 0) {
                suggestionsDiv.style.display = 'none';
                return;
            }

            // Lọc bác sĩ theo tên
            const filtered = allDoctors.filter(d => d.name.toLowerCase().includes(searchText));

            if (filtered.length === 0) {
                suggestionsDiv.style.display = 'none';
                return;
            }

            // Hiển thị gợi ý
            suggestionsDiv.innerHTML = filtered.map(d =>
                `<div style="padding: 10px; cursor: pointer; border-bottom: 1px solid #eee; transition: background-color 0.2s;" 
                      onmouseover="this.style.backgroundColor='#f5f5f5'" 
                      onmouseout="this.style.backgroundColor='white'" 
                      onclick="selectDoctor(${d.id}, '${d.name}')">${d.name}</div>`
            ).join('');
            suggestionsDiv.style.display = 'block';
        });

        // Hàm chọn bác sĩ
        function selectDoctor(doctorId, doctorName) {
            document.getElementById('doctorIdHidden').value = doctorId;
            document.getElementById('doctorSearch').value = doctorName;
            document.getElementById('doctorSuggestions').style.display = 'none';
            document.getElementById('selectedDoctorInfo').textContent = '✓ Đã chọn: ' + doctorName;
            document.getElementById('selectedDoctorInfo').style.display = 'block';
            selectedDoctorId = doctorId;
        }

        // Ẩn gợi ý khi click bên ngoài
        document.addEventListener('click', function (event) {
            const suggestionsDiv = document.getElementById('doctorSuggestions');
            const searchInput = document.getElementById('doctorSearch');
            if (!searchInput.contains(event.target) && !suggestionsDiv.contains(event.target)) {
                suggestionsDiv.style.display = 'none';
            }
        });

        // Khởi tạo khi page load
        window.addEventListener('load', initEditPage);
    </script>
}
}