@model IEnumerable<DoAnWeb.Models.DoctorSchedule>

@{
    ViewData["Title"] = "Quản lý ca làm bác sĩ";
}

<div class="employee-page-top">
    <div>
        <div class="employee-topbar-badge">
            <i class="bi bi-calendar2-week-fill"></i>
            Quản lý ca làm
        </div>
        <h1 class="employee-topbar-title">Danh sách ca làm bác sĩ</h1>
    </div>

    <a asp-area="Employee" asp-controller="DoctorSchedules" asp-action="Create" class="employee-topbar-btn employee-topbar-btn-primary">
        <i class="bi bi-plus-circle"></i>
        Thêm ca làm
    </a>
</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success employee-alert">@TempData["success"]</div>
}

<div class="employee-table-card">
    <div class="employee-table-head">
        <h3>Lịch làm việc bác sĩ</h3>
        <p>Quản lý các ca trực và thời gian làm việc của đội ngũ bác sĩ.</p>
    </div>

    <div class="employee-table-wrap">
        <table class="table employee-table mb-0">
            <thead>
                <tr>
                    <th>Bác sĩ</th>
                    <th>Chuyên khoa</th>
                    <th>Bắt đầu</th>
                    <th>Kết thúc</th>
                    <th>Số BN tối đa</th>
                    <th width="220">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Doctor.User.Name</td>
                            <td>@item.Doctor.Specialty</td>
                            <td>@item.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.EndTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <span class="employee-limit-badge">@item.MaxPatient bệnh nhân</span>
                            </td>
                            <td>
                                <div class="employee-table-actions">
                                    <a asp-area="Employee" asp-controller="DoctorSchedules" asp-action="Edit" asp-route-id="@item.Id" class="employee-action-btn employee-action-warning">
                                        <i class="bi bi-pencil-square"></i>
                                        Sửa
                                    </a>
                                    <a asp-area="Employee" asp-controller="DoctorSchedules" asp-action="Delete" asp-route-id="@item.Id" class="employee-action-btn employee-action-danger">
                                        <i class="bi bi-trash3"></i>
                                        Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="employee-empty">
                                <div class="employee-empty-icon">
                                    <i class="bi bi-calendar-minus"></i>
                                </div>
                                <h4>Chưa có ca làm nào</h4>
                                <p>Bạn có thể tạo mới ca làm cho bác sĩ từ nút “Thêm ca làm”.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>