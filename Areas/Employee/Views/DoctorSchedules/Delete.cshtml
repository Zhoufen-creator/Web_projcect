@model DoAnWeb.Models.DoctorSchedule

@{
    ViewData["Title"] = "Xóa ca làm";
}

<div class="employee-page-top">
    <div>
        <div class="employee-topbar-badge employee-badge-danger">
            <i class="bi bi-exclamation-triangle"></i>
            Xóa ca làm
        </div>
        <h1 class="employee-topbar-title">Xác nhận xóa ca làm bác sĩ</h1>
    </div>
</div>

<div class="employee-delete-card">
    <div class="employee-delete-icon">
        <i class="bi bi-trash3"></i>
    </div>

    <h3>Bạn chắc chắn muốn xóa ca làm này?</h3>
    <p>Ca trực này sẽ bị gỡ khỏi hệ thống. Hãy kiểm tra lại bác sĩ và khung giờ trước khi xác nhận.</p>

    <div class="employee-delete-info">
        <div class="employee-delete-row">
            <span>Bác sĩ</span>
            <strong>@Model.Doctor.User.Name</strong>
        </div>

        <div class="employee-delete-row">
            <span>Chuyên khoa</span>
            <strong>@Model.Doctor.Specialty?.Name</strong>
        </div>

        <div class="employee-delete-row">
            <span>Bắt đầu</span>
            <strong>@Model.StartTime.ToString("dd/MM/yyyy HH:mm")</strong>
        </div>

        <div class="employee-delete-row">
            <span>Kết thúc</span>
            <strong>@Model.EndTime.ToString("dd/MM/yyyy HH:mm")</strong>
        </div>
    </div>

    <form asp-area="Employee" asp-controller="DoctorSchedules" asp-action="Delete" method="post" class="employee-delete-actions justify-content-center">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="employee-danger-btn">
            <i class="bi bi-trash3"></i>
            Xóa ca làm
        </button>

        <a asp-area="Employee" asp-controller="DoctorSchedules" asp-action="Index" class="employee-secondary-btn">
            Hủy
        </a>
    </form>
</div>
