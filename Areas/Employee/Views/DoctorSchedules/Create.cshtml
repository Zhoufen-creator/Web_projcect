@model DoAnWeb.Areas.Employee.ViewModels.DoctorScheduleVM

@{
    ViewData["Title"] = "Thêm ca làm";
}

<div class="employee-page-top">
    <div>
        <div class="employee-topbar-badge">
            <i class="bi bi-calendar-plus"></i>
            Thêm ca làm
        </div>
        <h1 class="employee-topbar-title">Tạo ca làm mới cho bác sĩ</h1>
    </div>
</div>

<div class="employee-form-card">
    <div class="employee-form-head">
        <h3>Thông tin ca làm</h3>
        <p>Chọn chuyên khoa, chọn bác sĩ và thiết lập thời gian làm việc phù hợp.</p>
    </div>

    <form asp-area="Employee" asp-controller="DoctorSchedules" asp-action="Create" method="post" class="employee-form-body">
        <div asp-validation-summary="All" class="alert alert-danger employee-validation"></div>

        <div class="row g-3">
            <div class="col-lg-6">
                <div class="employee-form-group">
                    <label class="employee-label">Chuyên khoa</label>
                    <select asp-for="SpecialtyId" id="specialtySelect" asp-items="ViewBag.SpecialtyId" class="employee-select">
                        <option value="">-- Chọn chuyên khoa --</option>
                    </select>
                    <span asp-validation-for="SpecialtyId" class="text-danger"></span>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="employee-form-group">
                    <label class="employee-label">Bác sĩ</label>
                    <select asp-for="DoctorId" id="doctorSelect" asp-items="ViewBag.DoctorId" class="employee-select">
                        <option value="">-- Chọn bác sĩ --</option>
                    </select>
                    <span asp-validation-for="DoctorId" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-4">
                <div class="employee-form-group">
                    <label class="employee-label">Số bệnh nhân tối đa</label>
                    <input asp-for="MaxPatient" class="employee-input" />
                    <span asp-validation-for="MaxPatient" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-4">
                <div class="employee-form-group">
                    <label class="employee-label">Thời gian bắt đầu</label>
                    <input asp-for="StartTime" type="datetime-local" class="employee-input" />
                    <span asp-validation-for="StartTime" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-4">
                <div class="employee-form-group">
                    <label class="employee-label">Thời gian kết thúc</label>
                    <input asp-for="EndTime" type="datetime-local" class="employee-input" />
                    <span asp-validation-for="EndTime" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="employee-form-actions">
            <button type="submit" class="employee-primary-btn">
                <i class="bi bi-check2-circle"></i>
                Lưu ca làm
            </button>

            <a asp-area="Employee" asp-controller="DoctorSchedules" asp-action="Index" class="employee-secondary-btn">
                Quay lại
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('specialtySelect').addEventListener('change', async function () {
            const specialtyId = this.value;
            const doctorSelect = document.getElementById('doctorSelect');
            doctorSelect.innerHTML = '<option value="">-- Chọn bác sĩ --</option>';

            if (!specialtyId) return;

            try {
                const response = await fetch(`/Employee/DoctorSchedules/SearchDoctors?specialtyId=${specialtyId}`);
                if (response.ok) {
                    const doctors = await response.json();
                    doctorSelect.innerHTML += doctors
                        .map(d => `<option value="${d.id}">${d.name}</option>`)
                        .join('');
                }
            } catch (error) {
                console.error('Error fetching doctors:', error);
            }
        });
    </script>
}
