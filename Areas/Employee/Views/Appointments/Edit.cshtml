@model DoAnWeb.Areas.Employee.ViewModels.AppointmentAssignVM
@using DoAnWeb.Models

@{
    ViewData["Title"] = "Xử lý lịch hẹn";
}

<h2 class="mb-3">Xử lý lịch hẹn khám</h2>

<form asp-area="Employee" asp-controller="Appointments" asp-action="Edit" method="post">
    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label class="form-label">Bệnh nhân</label>
        <input asp-for="PatientName" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Lý do khám</label>
        <textarea asp-for="ReasonForVisit" class="form-control" rows="3" readonly></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Bác sĩ phụ trách</label>
        <select asp-for="DoctorId" asp-items="ViewBag.DoctorId" class="form-select">
            <option value="">-- Chọn bác sĩ --</option>
        </select>
        <span asp-validation-for="DoctorId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Thời gian khám</label>
        <input asp-for="ScheduledDate" type="datetime-local" class="form-control" />
        <span asp-validation-for="ScheduledDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Trạng thái</label>
        <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<AppointmentStatus>()"></select>
    </div>

    <button type="submit" class="btn btn-success">Lưu thay đổi</button>
    <a asp-area="Employee" asp-controller="Appointments" asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}