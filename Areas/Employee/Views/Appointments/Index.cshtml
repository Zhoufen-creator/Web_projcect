@model IEnumerable<DoAnWeb.Models.Appointment>

@{
    ViewData["Title"] = "Quản lý lịch hẹn";
}

<h2 class="mb-3">Quản lý lịch hẹn khám</h2>

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Bệnh nhân</th>
            <th>Bác sĩ</th>
            <th>Ngày khám</th>
            <th>Lý do khám</th>
            <th>Trạng thái</th>
            <th width="140">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Patient.User.Name</td>
                <td>@item.Doctor.User.Name</td>
                <td>@item.ScheduledDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@item.ReasonForVisit</td>
                <td>@item.Status</td>
                <td>
                    <a asp-area="Employee" asp-controller="Appointments" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                        Xử lý
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>