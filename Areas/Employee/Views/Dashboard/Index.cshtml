@{
    ViewData["Title"] = "Bảng điều khiển nhân viên";
}

<div class="employee-topbar">
    <div>
        <div class="employee-topbar-badge">
            <i class="bi bi-shield-check"></i>
            Hệ thống hỗ trợ điều phối bệnh viện
        </div>
        <h1 class="employee-topbar-title">Bảng điều khiển nhân viên</h1>
    </div>
</div>

<div class="employee-hero employee-hero-dashboard">
    <div class="employee-hero-main employee-hero-main-compact">
        <div class="employee-page-badge">
            <i class="bi bi-briefcase-fill"></i>
            Trung tâm điều phối hành chính
        </div>

        <h2>Không gian làm việc dành cho nhân viên với thao tác rõ ràng, nhanh và chuyên nghiệp</h2>
        <p>
            Theo dõi lịch hẹn, phân công ca làm cho bác sĩ và gửi thông báo đến bệnh nhân
            trên một giao diện trực quan, đồng bộ và dễ thao tác hơn trong quá trình vận hành.
        </p>
    </div>

    <div class="employee-highlight-card">
        <h3>Ưu tiên trong ca làm việc</h3>
        <p>
            Tập trung xử lý các tác vụ quan trọng trong ngày để hạn chế sai sót và giảm thời gian thao tác.
        </p>

        <div class="employee-highlight-list">
            <div class="employee-highlight-item">
                <i class="bi bi-calendar2-week"></i>
                <div>
                    <strong>Ca làm bác sĩ</strong>
                    <span>Thiết lập lịch trực theo khung giờ và khả năng tiếp nhận.</span>
                </div>
            </div>

            <div class="employee-highlight-item">
                <i class="bi bi-journal-check"></i>
                <div>
                    <strong>Lịch hẹn khám</strong>
                    <span>Phân công bác sĩ và cập nhật thời gian khám phù hợp.</span>
                </div>
            </div>

            <div class="employee-highlight-item">
                <i class="bi bi-bell"></i>
                <div>
                    <strong>Thông báo bệnh nhân</strong>
                    <span>Gửi nhắc lịch và thông tin cần thiết nhanh chóng, rõ ràng.</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="employee-stats-grid">
    <div class="employee-stat-card">
        <div class="employee-stat-icon">
            <i class="bi bi-calendar2-week-fill"></i>
        </div>
        <div class="employee-stat-text">
            <strong>Ca làm bác sĩ</strong>
            <span>Thiết lập và cập nhật ca trực thuận tiện theo lịch vận hành.</span>
        </div>
    </div>

    <div class="employee-stat-card">
        <div class="employee-stat-icon">
            <i class="bi bi-clipboard2-pulse-fill"></i>
        </div>
        <div class="employee-stat-text">
            <strong>Lịch hẹn khám</strong>
            <span>Theo dõi, xác nhận và điều phối lịch khám trong ngày.</span>
        </div>
    </div>

    <div class="employee-stat-card">
        <div class="employee-stat-icon">
            <i class="bi bi-envelope-paper-fill"></i>
        </div>
        <div class="employee-stat-text">
            <strong>Thông báo</strong>
            <span>Gửi thông tin đến bệnh nhân nhanh và đúng đối tượng.</span>
        </div>
    </div>
</div>

<div class="employee-quick-grid">
    <a href="@Url.Action("Index", "DoctorSchedules", new { area = "Employee" })" class="employee-quick-card">
        <div class="employee-quick-icon">
            <i class="bi bi-calendar-plus"></i>
        </div>
        <div class="employee-quick-content">
            <h3>Phân công ca làm cho bác sĩ</h3>
            <p>Quản lý lịch trực, thời gian làm việc và số lượng bệnh nhân tối đa.</p>
            <span>Mở danh sách ca làm <i class="bi bi-arrow-right-short"></i></span>
        </div>
    </a>

    <a href="@Url.Action("Index", "Appointments", new { area = "Employee" })" class="employee-quick-card">
        <div class="employee-quick-icon">
            <i class="bi bi-journal-check"></i>
        </div>
        <div class="employee-quick-content">
            <h3>Duyệt và sắp lịch hẹn khám</h3>
            <p>Gán bác sĩ, chỉnh thời gian khám và cập nhật trạng thái lịch hẹn.</p>
            <span>Đi tới lịch hẹn <i class="bi bi-arrow-right-short"></i></span>
        </div>
    </a>

    <a href="@Url.Action("Index", "Notifications", new { area = "Employee" })" class="employee-quick-card">
        <div class="employee-quick-icon">
            <i class="bi bi-send-check"></i>
        </div>
        <div class="employee-quick-content">
            <h3>Gửi thông báo cho bệnh nhân</h3>
            <p>Tạo thông báo nhanh để nhắc lịch hoặc cập nhật thông tin cần thiết.</p>
            <span>Mở thông báo <i class="bi bi-arrow-right-short"></i></span>
        </div>
    </a>
</div>