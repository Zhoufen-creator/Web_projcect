@model DoAnWeb.Areas.Admin.ViewModels.UserViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Thêm tài khoản";
}

<section class="admin-page-section">
    <div class="container-xxl">
        <div class="admin-page-header">
            <div>
                <span class="admin-page-badge">Admin Panel</span>
                <h1>Thêm tài khoản mới</h1>
                <p>Tạo tài khoản người dùng và gán quyền truy cập phù hợp trong hệ thống.</p>
            </div>

            <a asp-action="Index" class="admin-outline-btn">
                <i class="bi bi-arrow-left"></i>
                Quay lại danh sách
            </a>
        </div>

        <div class="admin-form-wrapper">
            <div class="admin-form-card">
                <div class="admin-form-card-head">
                    <h3>Thông tin tài khoản</h3>
                    <p>Nhập đầy đủ thông tin để khởi tạo hồ sơ người dùng.</p>
                </div>

                <form asp-action="Create" method="post" class="admin-form-grid">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="alert alert-danger admin-validation"></div>

                    <div class="admin-form-group">
                        <label asp-for="Name" class="form-label">Họ và tên</label>
                        <input asp-for="Name" class="form-control admin-input" placeholder="Nhập họ và tên" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control admin-input" placeholder="Nhập email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="PhoneNumber" class="form-label">Số điện thoại</label>
                        <input asp-for="PhoneNumber" class="form-control admin-input" placeholder="Nhập số điện thoại" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="Gender" class="form-label">Giới tính</label>
                        <select asp-for="Gender" class="form-select admin-input">
                            <option value="Nam">Nam</option>
                            <option value="Nữ">Nữ</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="DateOfBirth" class="form-label">Ngày sinh</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control admin-input" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="Role" class="form-label">Vai trò</label>
                        <select asp-for="Role" class="form-select admin-input"
                                asp-items="@(new SelectList((IEnumerable<string>)ViewBag.Roles))">
                            <option value="">-- Chọn vai trò --</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="admin-form-group admin-form-group-full">
                        <label asp-for="Address" class="form-label">Địa chỉ</label>
                        <input asp-for="Address" class="form-control admin-input" placeholder="Nhập địa chỉ liên hệ" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="Password" class="form-label">Mật khẩu</label>
                        <div class="admin-password-group">
                            <input asp-for="Password" type="password" class="form-control admin-input" placeholder="Nhập mật khẩu" id="Password" />
                            <button type="button" class="admin-password-toggle-btn" onclick="togglePassword('Password', this)" aria-label="Hiện hoặc ẩn mật khẩu">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="ConfirmPassword" class="form-label">Nhập lại mật khẩu</label>
                        <div class="admin-password-group">
                            <input asp-for="ConfirmPassword" type="password" class="form-control admin-input" placeholder="Nhập lại mật khẩu" id="ConfirmPassword" />
                            <button type="button" class="admin-password-toggle-btn" onclick="togglePassword('ConfirmPassword', this)" aria-label="Hiện hoặc ẩn mật khẩu">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="admin-form-group admin-form-group-full">
                        <div class="admin-check-card">
                            <input asp-for="IsSpam" class="form-check-input" />
                            <label asp-for="IsSpam" class="form-check-label">Đánh dấu tài khoản spam</label>
                        </div>
                    </div>

                    <div class="admin-form-actions">
                        <button type="submit" class="admin-primary-btn">
                            <i class="bi bi-save2"></i>
                            Lưu tài khoản
                        </button>

                        <a asp-action="Index" class="admin-secondary-btn">
                            Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const icon = button.querySelector("i");

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }
    </script>
}