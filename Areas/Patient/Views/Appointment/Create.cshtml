@model DoAnWeb.Areas.Patient.ViewModels.AppointmentCreateViewModel

@{
    ViewData["Title"] = "Đặt lịch khám";
}

@section Styles {
    <style>
        .patient-form-card {
            background: #fff;
            border: 1px solid #e8eef6;
            border-radius: 26px;
            box-shadow: 0 12px 30px rgba(15, 76, 151, 0.06);
            overflow: hidden;
        }

        .patient-form-head {
            padding: 24px 26px;
            background: linear-gradient(135deg, #0f4c97 0%, #2f7fe6 100%);
            color: #fff;
        }

        .patient-form-head h2 {
            margin: 0 0 8px;
            font-size: 2rem;
            font-weight: 800;
        }

        .patient-form-head p {
            margin: 0;
            color: rgba(255,255,255,0.92);
        }

        .patient-form-body {
            padding: 28px 26px;
        }

        .patient-form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 22px;
        }

        .patient-form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .patient-form-group-full {
            grid-column: 1 / -1;
        }

        .patient-label {
            font-weight: 700;
            color: #173e75;
        }

        .patient-input,
        .patient-select,
        .patient-textarea {
            width: 100%;
            min-height: 50px;
            border-radius: 14px;
            border: 1px solid #d9e5f2;
            padding: 12px 14px;
            box-shadow: none;
            color: #27466f;
            background: #fff;
        }

        .patient-textarea {
            min-height: 140px;
            resize: vertical;
        }

        .patient-input:focus,
        .patient-select:focus,
        .patient-textarea:focus {
            outline: none;
            border-color: #7daee7;
            box-shadow: 0 0 0 0.2rem rgba(15, 76, 151, 0.08);
        }

        .patient-form-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 8px;
        }

        .patient-btn-primary,
        .patient-btn-light {
            min-height: 48px;
            padding: 0 20px;
            border-radius: 14px;
            font-weight: 700;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border: none;
        }

        .patient-btn-primary {
            background: linear-gradient(135deg, #0f4c97 0%, #2f7fe6 100%);
            color: #fff;
        }

        .patient-btn-primary:hover {
            color: #fff;
        }

        .patient-btn-light {
            background: #fff;
            color: #1d4f8f;
            border: 1px solid #dce7f3;
        }

        .patient-btn-light:hover {
            color: #1d4f8f;
            background: #f8fbff;
        }

        @@media (max-width: 991.98px) {
            .patient-form-grid {
                grid-template-columns: 1fr;
            }

            .patient-form-group-full {
                grid-column: auto;
            }
        }

        @@media (max-width: 767.98px) {
            .patient-form-head,
            .patient-form-body {
                padding: 18px;
            }

            .patient-form-actions {
                flex-direction: column;
            }

            .patient-btn-primary,
            .patient-btn-light {
                width: 100%;
            }
        }
    </style>
}

<div class="patient-form-card">
    <div class="patient-form-head">
        <h2>Đăng ký lịch hẹn khám</h2>
        <p>Chọn bác sĩ, thời gian phù hợp và gửi yêu cầu đặt lịch trực tiếp trên hệ thống.</p>
    </div>

    <div class="patient-form-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="patient-form-grid">
                <div class="patient-form-group">
                    <label asp-for="DoctorId" class="patient-label">Chọn bác sĩ</label>
                    <select asp-for="DoctorId" class="patient-select">
                        <option value="">-- Chọn bác sĩ phụ trách --</option>
                        @foreach (var doctor in Model.Doctors)
                        {
                            <option value="@doctor.Id">@doctor.Name - @doctor.Specialty</option>
                        }
                    </select>
                    <span asp-validation-for="DoctorId" class="text-danger"></span>
                </div>

                <div class="patient-form-group">
                    <label asp-for="ScheduledDate" class="patient-label">Ngày giờ khám</label>
                    <input asp-for="ScheduledDate" type="datetime-local" class="patient-input" />
                    <span asp-validation-for="ScheduledDate" class="text-danger"></span>
                </div>

                <div class="patient-form-group patient-form-group-full">
                    <label asp-for="ReasonForVisit" class="patient-label">Lý do khám</label>
                    <textarea asp-for="ReasonForVisit" class="patient-textarea" placeholder="Mô tả triệu chứng hoặc nhu cầu khám của bạn..."></textarea>
                    <span asp-validation-for="ReasonForVisit" class="text-danger"></span>
                </div>
            </div>

            <div class="patient-form-actions">
                <button type="submit" class="patient-btn-primary">
                    <i class="fa-solid fa-paper-plane"></i>
                    Gửi yêu cầu đặt lịch
                </button>

                <a href="/Patient/Appointment/Index" class="patient-btn-light">
                    <i class="fa-solid fa-arrow-left"></i>
                    Quay lại danh sách
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}