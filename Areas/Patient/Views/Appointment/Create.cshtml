@model DoAnWeb.Areas.Patient.ViewModels.AppointmentCreateViewModel

@{
    ViewData["Title"] = "Đặt lịch khám";
}

@section Styles {
    <link rel="stylesheet" href="~/css/patient/appointment-create.css" asp-append-version="true" />
}

<div class="patient-form-card">
    <div class="patient-form-head">
        <h2>Đăng ký lịch hẹn khám</h2>
        <p>Nhập thời gian và mô tả triệu chứng. Hệ thống sẽ tự động gợi ý chuyên khoa và sắp xếp bác sĩ phù hợp.</p>
    </div>

    <div class="patient-form-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="patient-form-grid">
                <div class="patient-form-group">
                    <label asp-for="ScheduledDate" class="patient-label">Ngày giờ khám</label>
                    <input asp-for="ScheduledDate" type="datetime-local" class="patient-input" />
                    <span asp-validation-for="ScheduledDate" class="text-danger"></span>
                </div>

                <div class="patient-form-group patient-form-group-full">
                    <label asp-for="ReasonForVisit" class="patient-label">Lý do khám</label>
                    <textarea asp-for="ReasonForVisit" class="patient-textarea" placeholder="Mô tả triệu chứng hoặc nhu cầu khám của bạn..."></textarea>
                    <span asp-validation-for="ReasonForVisit" class="text-danger"></span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.PredictedSpecialty))
            {
                <div class="patient-predict-card">
                    <h4>Gợi ý chuyên khoa từ mô tả bệnh nhân</h4>

                    <div class="patient-predict-row">
                        <strong>Chuyên khoa gợi ý:</strong> @Model.PredictedSpecialty
                    </div>

                    <div class="patient-predict-row">
                        <strong>Điểm khớp:</strong> @Model.PredictionScore
                    </div>

                    <div class="patient-predict-row">
                        <strong>Nhận xét:</strong> @(string.IsNullOrWhiteSpace(Model.PredictionMessage) ? "Không có nhận xét." : Model.PredictionMessage)
                    </div>

                    @if (Model.MatchedKeywords != null && Model.MatchedKeywords.Any())
                    {
                        <div class="patient-predict-row">
                            <strong>Từ khóa hệ thống nhận diện:</strong><br />
                            @foreach (var keyword in Model.MatchedKeywords)
                            {
                                <span class="patient-predict-tag">@keyword</span>
                            }
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.SuggestedDoctorMessage))
            {
                <div class="patient-doctor-suggest-card">
                    <h4>Hệ thống tự động sắp xếp bác sĩ</h4>

                    <div class="patient-predict-row">
                        <strong>Thông báo:</strong> @Model.SuggestedDoctorMessage
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.SuggestedDoctorName))
                    {
                        <div class="patient-predict-row">
                            <strong>Bác sĩ được sắp xếp:</strong> @Model.SuggestedDoctorName
                        </div>

                        <div class="patient-predict-row">
                            <strong>Số chỗ còn lại trong ca:</strong> @Model.SuggestedRemainingSlots
                        </div>
                    }
                </div>
            }

            <div class="patient-form-actions">
                <button type="submit" class="patient-btn-primary">
                    <i class="fa-solid fa-paper-plane"></i>
                    Gửi yêu cầu đặt lịch
                </button>

                <a href="/Patient/Appointment/Index" class="patient-btn-light">
                    <i class="fa-solid fa-arrow-left"></i>
                    Quay lại danh sách
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
