@model DoAnWeb.Areas.Patient.ViewModels.AppointmentCreateViewModel

@{
    ViewData["Title"] = "Dat lich kham";
}

@section Styles {
    <link rel="stylesheet" href="~/css/patient/appointment-create.css" asp-append-version="true" />
}

<div class="patient-form-card">
    <div class="patient-form-head">
        <h2>Dang ky lich hen kham</h2>
        <p>Nhap thoi gian va mo ta trieu chung. He thong se tu dong goi y chuyen khoa va sap xep bac si phu hop.</p>
    </div>

    <div class="patient-form-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="patient-form-grid">
                <div class="patient-form-group">
                    <label asp-for="ScheduledDate" class="patient-label">Ngay gio kham</label>
                    <input asp-for="ScheduledDate" type="datetime-local" class="patient-input" />
                    <span asp-validation-for="ScheduledDate" class="text-danger"></span>
                </div>

                <div class="patient-form-group patient-form-group-full">
                    <label asp-for="ReasonForVisit" class="patient-label">Ly do kham</label>
                    <textarea asp-for="ReasonForVisit" class="patient-textarea" placeholder="Mo ta trieu chung hoac nhu cau kham cua ban..."></textarea>
                    <span asp-validation-for="ReasonForVisit" class="text-danger"></span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.PredictedSpecialty))
            {
                <div class="patient-predict-card">
                    <h4>Goi y chuyen khoa tu mo ta benh nhan</h4>

                    <div class="patient-predict-row">
                        <strong>Chuyen khoa goi y:</strong> @Model.PredictedSpecialty
                    </div>

                    <div class="patient-predict-row">
                        <strong>Diem khop:</strong> @Model.PredictionScore
                    </div>

                    <div class="patient-predict-row">
                        <strong>Nhan xet:</strong> @(string.IsNullOrWhiteSpace(Model.PredictionMessage) ? "Khong co nhan xet." : Model.PredictionMessage)
                    </div>

                    @if (Model.MatchedKeywords != null && Model.MatchedKeywords.Any())
                    {
                        <div class="patient-predict-row">
                            <strong>Tu khoa he thong nhan dien:</strong><br />
                            @foreach (var keyword in Model.MatchedKeywords)
                            {
                                <span class="patient-predict-tag">@keyword</span>
                            }
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.SuggestedDoctorMessage))
            {
                <div class="patient-doctor-suggest-card">
                    <h4>He thong tu dong sap xep bac si</h4>

                    <div class="patient-predict-row">
                        <strong>Thong bao:</strong> @Model.SuggestedDoctorMessage
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.SuggestedDoctorName))
                    {
                        <div class="patient-predict-row">
                            <strong>Bac si duoc sap xep:</strong> @Model.SuggestedDoctorName
                        </div>

                        <div class="patient-predict-row">
                            <strong>So cho con lai trong ca:</strong> @Model.SuggestedRemainingSlots
                        </div>
                    }
                </div>
            }

            <div class="patient-form-actions">
                <button type="submit" class="patient-btn-primary">
                    <i class="fa-solid fa-paper-plane"></i>
                    Gui yeu cau dat lich
                </button>

                <a href="/Patient/Appointment/Index" class="patient-btn-light">
                    <i class="fa-solid fa-arrow-left"></i>
                    Quay lai danh sach
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
