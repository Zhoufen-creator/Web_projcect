@model List<DoAnWeb.Models.Appointment>

@{
    ViewData["Title"] = "Lịch hẹn khám";
}

@section Styles {
    <link rel="stylesheet" href="~/css/patient/appointment-index.css" asp-append-version="true" />
}

<div class="patient-page-header">
    <div>
        <h2>Danh sách lịch hẹn</h2>
        <p>Theo dõi toàn bộ lịch khám đã đăng ký trong hệ thống bệnh viện.</p>
    </div>

    <a href="/Patient/Appointment/Create" class="patient-page-btn">
        <i class="fa-solid fa-calendar-plus"></i>
        Đặt lịch mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success rounded-4">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger rounded-4">@TempData["Error"]</div>
}

<div class="patient-table-card">
    <div class="patient-table-head">
        <h3>Lịch hẹn khám</h3>
        <p>Thông tin lịch hẹn, trạng thái xử lý và tình trạng check-in.</p>
    </div>

    <div class="table-responsive">
        <table class="table patient-table-modern align-middle">
            <thead>
                <tr>
                    <th>Ngày khám</th>
                    <th>Bác sĩ</th>
                    <th>Chuyên khoa</th>
                    <th>Lý do khám</th>
                    <th>Trạng thái</th>
                    <th>Check-in</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ScheduledDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(item.Doctor?.User?.Name ?? "Chưa cập nhật")</td>
                            <td>@(item.Doctor?.Specialty?.Name ?? "Chưa cập nhật")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ReasonForVisit) ? "Không có ghi chú" : item.ReasonForVisit)</td>
                            <td>
                                <span class="patient-status-badge">@item.Status</span>
                            </td>
                            <td>
                                @if (item.IsCheckedIn)
                                {
                                    <span class="patient-status-badge patient-checkin-done">Đã check-in</span>
                                }
                                else
                                {
                                    <span class="patient-status-badge patient-checkin-wait">Chưa check-in</span>
                                }
                            </td>
                            <td>
                                @if (item.Status != DoAnWeb.Models.AppointmentStatus.Cancelled
                               && item.Status != DoAnWeb.Models.AppointmentStatus.Completed
                               && !item.IsCheckedIn)
                                {
                                    <a asp-area="Patient"
                                       asp-controller="Appointment"
                                       asp-action="Cancel"
                                       asp-route-id="@item.Id"
                                       class="patient-cancel-btn">
                                        <i class="fa-solid fa-ban me-2"></i>
                                        Hủy lịch
                                    </a>
                                }
                                else if (item.Status == DoAnWeb.Models.AppointmentStatus.Cancelled)
                                {
                                    <span class="patient-status-badge patient-status-cancelled">Đã hủy</span>
                                }
                                else
                                {
                                    <span class="text-muted">Không khả dụng</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Bạn chưa có lịch hẹn nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
