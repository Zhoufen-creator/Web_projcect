@model DoAnWeb.Areas.Patient.ViewModels.CancelAppointmentViewModel

@{
    ViewData["Title"] = "Hủy lịch hẹn";
}

@section Styles {
    <style>
        .patient-cancel-card {
            background: #fff;
            border: 1px solid #e8eef6;
            border-radius: 26px;
            box-shadow: 0 12px 30px rgba(15, 76, 151, 0.06);
            overflow: hidden;
        }

        .patient-cancel-head {
            padding: 24px 26px;
            background: linear-gradient(135deg, #b52f3f 0%, #e05768 100%);
            color: #fff;
        }

        .patient-cancel-head h2 {
            margin: 0 0 8px;
            font-size: 2rem;
            font-weight: 800;
        }

        .patient-cancel-head p {
            margin: 0;
            color: rgba(255,255,255,0.92);
        }

        .patient-cancel-body {
            padding: 28px 26px;
        }

        .patient-info-box {
            background: #f8fbff;
            border: 1px solid #edf3fa;
            border-radius: 18px;
            padding: 16px;
            margin-bottom: 18px;
        }

        .patient-info-box .label {
            color: #7b8ba1;
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .patient-info-box .value {
            font-size: 1rem;
            font-weight: 700;
            color: #213d67;
        }

        .patient-label {
            font-weight: 700;
            color: #173e75;
            margin-bottom: 8px;
            display: block;
        }

        .patient-textarea {
            width: 100%;
            min-height: 120px;
            border-radius: 14px;
            border: 1px solid #d9e5f2;
            padding: 12px 14px;
            color: #27466f;
            background: #fff;
            resize: vertical;
        }

        .patient-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 18px;
        }

        .patient-danger-btn,
        .patient-light-btn {
            min-height: 48px;
            padding: 0 20px;
            border-radius: 14px;
            font-weight: 700;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border: none;
        }

        .patient-danger-btn {
            background: linear-gradient(135deg, #b52f3f 0%, #e05768 100%);
            color: #fff;
        }

        .patient-danger-btn:hover {
            color: #fff;
        }

        .patient-light-btn {
            background: #fff;
            color: #1d4f8f;
            border: 1px solid #dce7f3;
        }

        .patient-light-btn:hover {
            color: #1d4f8f;
            background: #f8fbff;
        }
    </style>
}

<div class="patient-cancel-card">
    <div class="patient-cancel-head">
        <h2>Hủy lịch hẹn khám</h2>
        <p>Vui lòng kiểm tra thông tin và nhập lý do trước khi xác nhận hủy lịch.</p>
    </div>

    <div class="patient-cancel-body">
        <div class="patient-info-box">
            <div class="label">Bác sĩ</div>
            <div class="value">@Model.DoctorName (@(string.IsNullOrWhiteSpace(Model.Specialty) ? "Chưa cập nhật" : Model.Specialty))</div>
        </div>

        <div class="patient-info-box">
            <div class="label">Ngày giờ khám</div>
            <div class="value">@Model.ScheduledDate.ToString("dd/MM/yyyy HH:mm")</div>
        </div>

        <div class="patient-info-box">
            <div class="label">Lý do khám ban đầu</div>
            <div class="value">@(string.IsNullOrWhiteSpace(Model.ReasonForVisit) ? "Không có ghi chú" : Model.ReasonForVisit)</div>
        </div>

        <form asp-area="Patient" asp-controller="Appointment" asp-action="Cancel" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ScheduledDate" />
            <input type="hidden" asp-for="DoctorName" />
            <input type="hidden" asp-for="Specialty" />
            <input type="hidden" asp-for="ReasonForVisit" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <label asp-for="CancellationReason" class="patient-label">Lý do hủy lịch</label>
            <textarea asp-for="CancellationReason" class="patient-textarea" placeholder="Nhập lý do hủy lịch..."></textarea>
            <span asp-validation-for="CancellationReason" class="text-danger"></span>

            <div class="patient-actions">
                <button type="submit" class="patient-danger-btn">
                    <i class="fa-solid fa-ban"></i>
                    Xác nhận hủy lịch
                </button>

                <a asp-area="Patient" asp-controller="Appointment" asp-action="Index" class="patient-light-btn">
                    <i class="fa-solid fa-arrow-left"></i>
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}