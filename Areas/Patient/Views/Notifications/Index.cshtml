@model IEnumerable<DoAnWeb.Models.Notification>

@{
    ViewData["Title"] = "Thông báo";
}

<section class="patient-card">
    <div class="patient-card-header">
        <h2>Thông báo của bạn</h2>
        <p>Theo dõi các cập nhật liên quan đến lịch hẹn, check-in và thông tin từ bệnh viện.</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table patient-table-modern align-middle">
                <thead>
                    <tr>
                        <th>Tiêu đề</th>
                        <th>Nội dung</th>
                        <th>Thời gian</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Message</td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @(item.IsRead ? "Đã đọc" : "Chưa đọc")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-muted">Bạn chưa có thông báo nào.</div>
    }
</section>
