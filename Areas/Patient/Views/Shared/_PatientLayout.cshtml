@using Microsoft.AspNetCore.Identity
@using DoAnWeb.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cổng bệnh nhân | An Phúc Hospital</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            margin: 0;
            background: #f4f7fb;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            color: #1f2a37;
        }

        .patient-shell {
            min-height: 100vh;
            display: flex;
        }

        .patient-sidebar {
            width: 280px;
            background: linear-gradient(180deg, #0f4c97 0%, #0a3770 100%);
            color: #fff;
            padding: 24px 18px;
            position: sticky;
            top: 0;
            height: 100vh;
            box-shadow: 8px 0 24px rgba(15, 76, 151, 0.12);
            z-index: 20;
        }

        .patient-brand {
            display: flex;
            align-items: center;
            gap: 14px;
            padding-bottom: 22px;
            border-bottom: 1px solid rgba(255,255,255,0.16);
            margin-bottom: 24px;
        }

        .patient-brand-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            background: rgba(255,255,255,0.14);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.35rem;
        }

        .patient-brand-title {
            font-size: 1.3rem;
            font-weight: 800;
            margin: 0;
            line-height: 1.2;
        }

        .patient-brand-subtitle {
            margin: 2px 0 0;
            font-size: 0.9rem;
            color: rgba(255,255,255,0.75);
        }

        .patient-userbox {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 18px;
            padding: 16px;
            margin-bottom: 24px;
        }

        .patient-userbox .small-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: rgba(255,255,255,0.68);
            margin-bottom: 6px;
        }

        .patient-userbox .name {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .patient-userbox .role-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 999px;
            background: rgba(255,255,255,0.14);
            font-size: 0.82rem;
            color: #fff;
        }

        .patient-menu-title {
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: rgba(255,255,255,0.62);
            margin: 18px 10px 12px;
        }

        .patient-menu {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .patient-menu a {
            text-decoration: none;
            color: rgba(255,255,255,0.9);
            padding: 13px 14px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
            transition: all 0.18s ease;
            position: relative;
            z-index: 2;
        }

        .patient-menu a i {
            width: 18px;
            text-align: center;
        }

        .patient-menu a:hover {
            background: rgba(255,255,255,0.12);
            color: #fff;
            transform: translateX(2px);
        }

        .patient-menu a.active {
            background: #ffffff;
            color: #0f4c97;
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
        }

        .patient-sidebar-footer {
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.16);
        }

        .patient-sidebar-footer a {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: #fff;
            font-weight: 600;
            background: rgba(255,255,255,0.12);
            padding: 12px 16px;
            border-radius: 12px;
        }

        .patient-main {
            flex: 1;
            min-width: 0;
            position: relative;
            z-index: 1;
        }

        .patient-topbar {
            background: #fff;
            border-bottom: 1px solid #e5edf7;
            padding: 18px 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 18px;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .patient-topbar-title h1 {
            margin: 0;
            font-size: 1.55rem;
            font-weight: 800;
            color: #133b73;
        }

        .patient-topbar-title p {
            margin: 4px 0 0;
            color: #6b7c93;
            font-size: 0.96rem;
        }

        .patient-topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .patient-chip {
            background: #eef5ff;
            color: #0f4c97;
            padding: 10px 14px;
            border-radius: 999px;
            font-weight: 700;
            font-size: 0.92rem;
            white-space: nowrap;
        }

        .patient-content {
            padding: 28px;
        }

        @@media (max-width: 991.98px) {
            .patient-shell {
                flex-direction: column;
            }

            .patient-sidebar {
                width: 100%;
                height: auto;
                position: relative;
                border-radius: 0 0 22px 22px;
            }

            .patient-topbar {
                padding: 16px 18px;
                flex-direction: column;
                align-items: flex-start;
            }

            .patient-content {
                padding: 18px;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        var currentUser = await UserManager.GetUserAsync(User);
    }

    <div class="patient-shell">
        <aside class="patient-sidebar">
            <div class="patient-brand">
                <div class="patient-brand-icon">
                    <i class="fa-solid fa-hospital"></i>
                </div>
                <div>
                    <h2 class="patient-brand-title">An Phúc Hospital</h2>
                    <p class="patient-brand-subtitle">Cổng thông tin bệnh nhân</p>
                </div>
            </div>

            <div class="patient-userbox">
                <div class="small-label">Tài khoản đang đăng nhập</div>
                <div class="name">@((currentUser?.Name ?? User.Identity?.Name ?? "Bệnh nhân"))</div>
                <span class="role-badge">
                    <i class="fa-solid fa-user-injured me-1"></i> Bệnh nhân
                </span>
            </div>

            <div class="patient-menu-title">Điều hướng chính</div>

            <nav class="patient-menu">
                <a class="@(currentController == "Dashboard" ? "active" : "")"
                   href="/Patient/Dashboard/Index">
                    <i class="fa-solid fa-chart-line"></i>
                    <span>Tổng quan</span>
                </a>

                <a class="@((currentController == "Appointment" && currentAction == "Index") ? "active" : "")"
                   href="/Patient/Appointment/Index">
                    <i class="fa-solid fa-calendar-check"></i>
                    <span>Lịch hẹn khám</span>
                </a>

                <a class="@((currentController == "Appointment" && currentAction == "Create") ? "active" : "")"
                   href="/Patient/Appointment/Create">
                    <i class="fa-solid fa-calendar-plus"></i>
                    <span>Đặt lịch mới</span>
                </a>

                <a class="@(currentController == "MedicalHistory" ? "active" : "")"
                   href="/Patient/MedicalHistory/Index">
                    <i class="fa-solid fa-file-medical"></i>
                    <span>Lịch sử khám</span>
                </a>

                <a class="@(currentController == "Profile" ? "active" : "")"
                   href="/Patient/Profile/Index">
                    <i class="fa-solid fa-id-card"></i>
                    <span>Hồ sơ cá nhân</span>
                </a>
            </nav>

            <div class="patient-sidebar-footer">
                <a href="@Url.Action("Index", "Home", new { area = "" })">
                    <i class="fa-solid fa-house"></i>
                    <span>Về trang chủ</span>
                </a>
            </div>
        </aside>

        <main class="patient-main">
            <div class="patient-topbar">
                <div class="patient-topbar-title">
                    <h1>@ViewData["Title"]</h1>
                    <p>Quản lý thông tin khám chữa bệnh nhanh gọn, rõ ràng và chuyên nghiệp.</p>
                </div>

                <div class="patient-topbar-right">
                    <div class="patient-chip">
                        <i class="fa-solid fa-shield-heart me-1"></i>
                        Chăm sóc sức khỏe toàn diện
                    </div>
                </div>
            </div>

            <div class="patient-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>