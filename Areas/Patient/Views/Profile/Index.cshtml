@model DoAnWeb.Areas.Patient.ViewModels.PatientProfileViewModel

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

@section Styles {
    <link rel="stylesheet" href="~/css/patient/profile.css" asp-append-version="true" />
}

<div class="patient-profile-card">
    <div class="patient-profile-head">
        <h2>Thông tin cá nhân bệnh nhân</h2>
        <p>Cập nhật hồ sơ liên hệ và dữ liệu y tế cơ bản để bệnh viện hỗ trợ chính xác hơn.</p>
    </div>

    <div class="patient-profile-body">
        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success rounded-4">@ViewBag.Success</div>
        }

        <form asp-action="Index" method="post">
            <input type="hidden" asp-for="PatientId" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="patient-section-title">Thông tin liên hệ</div>

            <div class="patient-form-grid mb-4">
                <div class="patient-form-group">
                    <label asp-for="Name" class="patient-label">Họ tên</label>
                    <input asp-for="Name" class="patient-input" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="patient-form-group">
                    <label asp-for="Email" class="patient-label">Email</label>
                    <input asp-for="Email" class="patient-input" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="patient-form-group">
                    <label asp-for="PhoneNumber" class="patient-label">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="patient-input" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="patient-form-group">
                    <label asp-for="DateOfBirth" class="patient-label">Ngày sinh</label>
                    <input asp-for="DateOfBirth" type="date" class="patient-input" />
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>

                <div class="patient-form-group">
                    <label asp-for="Gender" class="patient-label">Giới tính</label>
                    <select asp-for="Gender" class="patient-select">
                        <option value="">-- Chọn giới tính --</option>
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                        <option value="Khác">Khác</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>

                <div class="patient-form-group">
                    <label asp-for="Address" class="patient-label">Địa chỉ</label>
                    <input asp-for="Address" class="patient-input" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
            </div>

            <div class="patient-section-title">Thông tin y tế cơ bản</div>

            <div class="patient-form-grid">
                <div class="patient-form-group">
                    <label asp-for="BloodType" class="patient-label">Nhóm máu</label>
                    <input asp-for="BloodType" class="patient-input" placeholder="Ví dụ: A+, O-" />
                    <span asp-validation-for="BloodType" class="text-danger"></span>
                </div>

                <div class="patient-form-group">
                    <label asp-for="HealthInsuranceNumber" class="patient-label">Số bảo hiểm y tế</label>
                    <input asp-for="HealthInsuranceNumber" class="patient-input" />
                    <span asp-validation-for="HealthInsuranceNumber" class="text-danger"></span>
                </div>

                <div class="patient-form-group">
                    <label asp-for="Height" class="patient-label">Chiều cao (cm)</label>
                    <input asp-for="Height" class="patient-input" />
                    <span asp-validation-for="Height" class="text-danger"></span>
                </div>

                <div class="patient-form-group">
                    <label asp-for="Weight" class="patient-label">Cân nặng (kg)</label>
                    <input asp-for="Weight" class="patient-input" />
                    <span asp-validation-for="Weight" class="text-danger"></span>
                </div>

                <div class="patient-form-group patient-form-group-full">
                    <label asp-for="MedicalHistory" class="patient-label">Tiền sử bệnh</label>
                    <textarea asp-for="MedicalHistory" class="patient-textarea" placeholder="Nhập thông tin bệnh nền, bệnh đã từng điều trị..."></textarea>
                    <span asp-validation-for="MedicalHistory" class="text-danger"></span>
                </div>

                <div class="patient-form-group patient-form-group-full">
                    <label asp-for="Allergies" class="patient-label">Dị ứng</label>
                    <textarea asp-for="Allergies" class="patient-textarea" placeholder="Ví dụ: dị ứng thuốc, thực phẩm, hóa chất..."></textarea>
                    <span asp-validation-for="Allergies" class="text-danger"></span>
                </div>
            </div>

            <div class="patient-form-actions">
                <button type="submit" class="patient-btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
