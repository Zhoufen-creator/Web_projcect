@model DoAnWeb.Areas.Patient.ViewModels.PatientProfileViewModel

@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container mt-4">
    <h2>Thông tin cá nhân</h2>

    @if (ViewBag.Success != null)
    {
        <div class="alert alert-success">@ViewBag.Success</div>
    }

    <form asp-action="Index" method="post">
        <input type="hidden" asp-for="PatientId" />

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Name" class="form-label">Họ tên</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="PhoneNumber" class="form-label">Số điện thoại</label>
                <input asp-for="PhoneNumber" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="DateOfBirth" class="form-label">Ngày sinh</label>
                <input asp-for="DateOfBirth" type="date" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Gender" class="form-label">Giới tính</label>
                <input asp-for="Gender" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Address" class="form-label">Địa chỉ</label>
                <input asp-for="Address" class="form-control" />
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="BloodType" class="form-label">Nhóm máu</label>
                <input asp-for="BloodType" class="form-control" />
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Height" class="form-label">Chiều cao (cm)</label>
                <input asp-for="Height" class="form-control" />
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Weight" class="form-label">Cân nặng (kg)</label>
                <input asp-for="Weight" class="form-control" />
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="HealthInsuranceNumber" class="form-label">Số BHYT</label>
                <input asp-for="HealthInsuranceNumber" class="form-control" />
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="MedicalHistory" class="form-label">Tiền sử bệnh</label>
                <textarea asp-for="MedicalHistory" class="form-control" rows="3"></textarea>
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="Allergies" class="form-label">Dị ứng</label>
                <textarea asp-for="Allergies" class="form-control" rows="3"></textarea>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}