@model List<DoAnWeb.Areas.Patient.ViewModels.MedicalHistoryViewModel>

@{
    ViewData["Title"] = "Lịch sử khám";
}

@section Styles {
    <link rel="stylesheet" href="~/css/patient/medical-history.css" asp-append-version="true" />
}

<div class="patient-history-header">
    <h2>Hồ sơ lịch sử khám bệnh</h2>
    <p>Tra cứu các lần khám, đơn thuốc và dịch vụ y tế đã thực hiện tại bệnh viện.</p>
</div>

@if (!Model.Any())
{
    <div class="patient-history-card">
        <div class="patient-history-card-body text-muted">
            Bạn chưa có lịch sử khám nào.
        </div>
    </div>
}
else
{
    @foreach (var item in Model)
    {
        <div class="patient-history-card">
            <div class="patient-history-card-head">
                <h3>
                    Phiếu khám #@item.ExaminationId - @item.ExaminationDate?.ToString("dd/MM/yyyy HH:mm")
                </h3>
            </div>

            <div class="patient-history-card-body">
                <div class="patient-history-grid">
                    <div class="patient-history-box">
                        <div class="label">Bác sĩ phụ trách</div>
                        <div class="value">@item.DoctorName</div>
                    </div>

                    <div class="patient-history-box">
                        <div class="label">Chuyên khoa</div>
                        <div class="value">@(string.IsNullOrWhiteSpace(item.Specialty) ? "Chưa cập nhật" : item.Specialty)</div>
                    </div>

                    <div class="patient-history-box">
                        <div class="label">Triệu chứng</div>
                        <div class="value">@(string.IsNullOrWhiteSpace(item.Symptoms) ? "Không có thông tin" : item.Symptoms)</div>
                    </div>

                    <div class="patient-history-box">
                        <div class="label">Chẩn đoán</div>
                        <div class="value">@(string.IsNullOrWhiteSpace(item.Diagnosis) ? "Không có thông tin" : item.Diagnosis)</div>
                    </div>

                    <div class="patient-history-box">
                        <div class="label">Lời dặn của bác sĩ</div>
                        <div class="value">@(string.IsNullOrWhiteSpace(item.DoctorAvoid) ? "Không có ghi chú" : item.DoctorAvoid)</div>
                    </div>

                    <div class="patient-history-box">
                        <div class="label">Trạng thái</div>
                        <div class="value">@(string.IsNullOrWhiteSpace(item.Status) ? "Chưa cập nhật" : item.Status)</div>
                    </div>
                </div>

                <div class="patient-subtitle">Thuốc được kê</div>

                @if (item.Prescriptions.Any())
                {
                    <div class="table-responsive mb-3">
                        <table class="table patient-table-modern align-middle">
                            <thead>
                                <tr>
                                    <th>Tên thuốc</th>
                                    <th>Liều dùng</th>
                                    <th>Số lượng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var med in item.Prescriptions)
                                {
                                    <tr>
                                        <td>@med.MedicineName</td>
                                        <td>@(string.IsNullOrWhiteSpace(med.Dosage) ? "Theo chỉ định" : med.Dosage)</td>
                                        <td>@med.Quantity</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted mb-3">Không có thuốc được kê.</div>
                }

                <div class="patient-subtitle">Dịch vụ đã sử dụng</div>

                @if (item.Services.Any())
                {
                    <div class="table-responsive">
                        <table class="table patient-table-modern align-middle">
                            <thead>
                                <tr>
                                    <th>Tên dịch vụ</th>
                                    <th>Số lượng</th>
                                    <th>Kết quả</th>
                                    <th>Hoàn thành lúc</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var service in item.Services)
                                {
                                    <tr>
                                        <td>@service.ServiceName</td>
                                        <td>@service.Quantity</td>
                                        <td>@(string.IsNullOrWhiteSpace(service.Result) ? "Chưa có kết quả" : service.Result)</td>
                                        <td>@service.CompletedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Không có dịch vụ nào được sử dụng.</div>
                }
            </div>
        </div>
    }
}
