@using Microsoft.AspNetCore.Identity
@using DoAnWeb.Models

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bệnh viện Đa khoa An Phúc</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (ViewContext.RouteData.Values["area"]?.ToString() == "Admin")
    {
        <link rel="stylesheet" href="~/css/admin/admin.css" asp-append-version="true" />
    }
    <link rel="stylesheet" href="~/DoAnWeb.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentArea = ViewContext.RouteData.Values["area"]?.ToString();
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <header class="hospital-header">
        <div class="top-strip">
            <div class="container-xxl top-strip-inner">
                <div class="top-strip-left">
                    <span>
                        <i class="bi bi-heart-pulse"></i>
                        Bệnh viện Đa khoa An Phúc - Chăm sóc sức khỏe toàn diện
                    </span>
                </div>

                <div class="top-strip-right">
                    <span><i class="bi bi-telephone"></i> Hotline: 1900 6868</span>
                    <span><i class="bi bi-ambulance"></i> Cấp cứu 24/7: 028 3888 9999</span>
                    <span><i class="bi bi-envelope"></i> cskh@anphuchospital.vn</span>
                </div>
            </div>
        </div>

        <div class="main-header">
            <div class="container-xxl main-header-inner">
                <a href="@Url.Action("Index", "Home", new { area = "" })" class="brand-box">
                    <div class="brand-icon">
                        <i class="bi bi-hospital"></i>
                    </div>
                    <div class="brand-content">
                        <h1>An Phúc Hospital</h1>
                        <p>Bệnh viện Đa khoa An Phúc</p>
                    </div>
                </a>

                <div class="header-right">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="user-badge">
                            <i class="bi bi-person-circle"></i>
                            <span>@User.Identity.Name</span>
                        </div>

                        <a class="btn header-btn header-btn-danger"
                           href="@Url.Action("Logout", "Account", new { area = "" })">
                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                        </a>
                    }
                    else
                    {
                        <a class="btn header-btn header-btn-primary"
                           href="@Url.Action("Login", "Account", new { area = "" })">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                        </a>
                    }
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-xl hospital-nav">
            <div class="container-xxl hospital-nav-inner">
                <button class="navbar-toggler nav-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu" aria-controls="mainMenu" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list"></i>
                </button>

                <div class="collapse navbar-collapse justify-content-center" id="mainMenu">
                    <ul class="navbar-nav nav-menu">
                        <li class="nav-item">
                            <a class="nav-link @((string.IsNullOrEmpty(currentArea) && currentController == "Home" && currentAction == "Index") ? "active" : "")"
                               href="@Url.Action("Index", "Home", new { area = "" })">
                                Trang chủ
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @((string.IsNullOrEmpty(currentArea) && currentController == "Home" && currentAction == "Privacy") ? "active" : "")"
                               href="@Url.Action("Privacy", "Home", new { area = "" })">
                                Giới thiệu
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @((currentArea == "Admin" && currentController == "Dashboard") ? "active" : "")"
                                       href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
                                        Admin
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link @((currentArea == "Admin" && currentController == "Users") ? "active" : "")"
                                       href="@Url.Action("Index", "Users", new { area = "Admin" })">
                                        Quản lý tài khoản
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Doctor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(currentArea == "Doctor" ? "active" : "")"
                                       href="@Url.Action("Index", "Dashboard", new { area = "Doctor" })">
                                        Bác sĩ
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Patient"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(currentArea == "Patient" ? "active" : "")"
                                       href="/Patient/Dashboard/Index">
                                        Bệnh nhân
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Employee"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(currentArea == "Employee" ? "active" : "")"
                                       href="@Url.Action("Index", "Dashboard", new { area = "Employee" })">
                                        Nhân viên
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="hospital-footer">
        <div class="container-xxl footer-grid">
            <div>
                <div class="footer-title">Bệnh viện Đa khoa An Phúc</div>
                <p class="footer-text">
                    Địa chỉ: 86 Nguyễn Tri Phương, Phường 9, Quận 5, TP. Hồ Chí Minh.
                    Hệ thống quản lý bệnh viện trực quan, đồng bộ và sẵn sàng mở rộng theo mô hình vận hành thực tế.
                </p>
            </div>

            <div>
                <div class="footer-heading">Điều hướng</div>
                <a href="@Url.Action("Index", "Home", new { area = "" })" class="footer-link">Trang chủ</a>
                <a href="@Url.Action("Privacy", "Home", new { area = "" })" class="footer-link">Giới thiệu</a>
            </div>

            <div>
                <div class="footer-heading">Liên hệ</div>
                <p class="footer-text mb-1">Hotline: 1900 6868</p>
                <p class="footer-text mb-1">Cấp cứu 24/7: 028 3888 9999</p>
                <p class="footer-text mb-0">Email: cskh@anphuchospital.vn</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
