@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<section class="login-shell">
    <div class="login-panel" style="max-width: 760px; margin: 2rem auto;">
        <div class="login-branding" style="width: 100%;">
            <div class="login-badge">Permission Required</div>
            <h1>Bạn không có quyền truy cập trang này</h1>
            <p>
                Tài khoản hiện tại không đủ quyền để thực hiện thao tác vừa rồi.
                Hãy quay lại đúng phân hệ hoặc đăng nhập bằng tài khoản có quyền phù hợp.
            </p>

            <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 1.5rem;">
                <a asp-controller="Home" asp-action="Index" class="login-button" style="text-decoration: none; text-align: center;">
                    Về trang chủ
                </a>
                <a asp-controller="Account" asp-action="Login" class="login-button-secondary" style="text-decoration: none; text-align: center;">
                    Đăng nhập lại
                </a>
            </div>
        </div>
    </div>
</section>
